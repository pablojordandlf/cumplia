{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "apps/web"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "FastAPI API",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "api"],
      "port": 8000
    },
    {
      "name": "PostgreSQL DB",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "db"],
      "port": 5432
    }
  ]
}
